# Application Settings
APP_NAME="LLM Inference API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT="production"

# Server
HOST="0.0.0.0"
PORT=8000
WORKERS=4

# Authentication
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (for rate limiting, caching, session storage)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""
REDIS_SSL=false

# Ollama Instances (GPU-mapped)
# V100 (16GB) - Large models: qwen3:32b, deepseek-r1:32b
OLLAMA_V100_HOST="localhost"
OLLAMA_V100_PORT=11434

# P40 (24GB) - Medium/Large models: mistral-small3.2, llama3.1:8b
OLLAMA_P40_HOST="localhost"
OLLAMA_P40_PORT=11435

# RTX 3060 (12GB) - Small models: qwen2.5-coder:7b, hermes3, qwen3-vl, granite4.1:3b
OLLAMA_3060_HOST="localhost"
OLLAMA_3060_PORT=11436

# Model-to-GPU Routing Rules
# Format: model_name:gpu_type (v100, p40, 3060, auto)
MODEL_ROUTING_RULES="qwen3:32b:v100,deepseek-r1:32b:v100,mistral-small3.2:p40,llama3.1:8b:p40,qwen2.5-coder:7b:3060,hermes3:3060,qwen3-vl:3060,granite4.1:3b:3060"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_BURST=10

# Usage Tracking
USAGE_TRACKING_ENABLED=true
USAGE_RETENTION_DAYS=30

# Health Checks
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE="/var/log/llm-inference-api/app.log"

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# CORS
CORS_ORIGINS="*"
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"

# Request Limits
MAX_REQUEST_SIZE_MB=50
REQUEST_TIMEOUT_SECONDS=300
STREAM_TIMEOUT_SECONDS=60