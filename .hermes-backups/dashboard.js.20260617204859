function renderGPUGrid() {
  var c = document.getElementById('gpu-grid');
  if (!c) return;
  if (!state.gpus.length) { c.innerHTML = '<div class="gpu-card loading">No GPU data</div>'; return; }
  c.innerHTML = state.gpus.map(function(g, i) { return createGPUCard(g, i); }).join('');
}

function renderLaneGrid() {
  var c = document.getElementById('lane-grid');
  if (!c) return;
  if (!state.ollamaLanes.length) { c.innerHTML = '<div class="lane-card loading">No lane data</div>'; return; }
  c.innerHTML = state.ollamaLanes.map(createLaneCard).join('');
}

function logActivity(msg, type, xp) {
  if (typeof type === 'undefined') type = 'system';
  if (typeof xp === 'undefined') xp = 0;
  var timeStr = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  state.activityLog.unshift({ msg: msg, type: type, xp: xp, time: timeStr });
  if (state.activityLog.length > 100) state.activityLog.pop();
  renderActivityLog();
  if (xp > 0) awardXP(xp, msg);
  StateManager.save(state);
}

function renderActivityLog() {
  var c = document.getElementById('activity-log');
  if (!c) return;
  c.innerHTML = state.activityLog.slice(-50).reverse().map(function(a) {
    return '<li class="activity-item ' + a.type + '"><span>' + a.msg + '</span>' + (a.xp ? '<span class="badge-inline badge-purple">+' + a.xp + ' XP</span>' : '') + '<span class="activity-time">' + a.time + '</span></li>';
  }).join('');
  c.scrollTop = 0;
}

function updateXPUI() {
  var fill = document.getElementById('xp-fill');
  var txt = document.getElementById('xp-text');
  var pct = state.xpToNext > 0 ? (state.xp / state.xpToNext) * 100 : 0;
  if (fill) fill.style.width = Math.min(pct, 100) + '%';
  if (txt) txt.textContent = 'Level ' + state.level + ' • ' + state.xp + ' / ' + state.xpToNext + ' XP';
}

function updateBadgesUI() {
  var c = document.getElementById('badges-grid');
  if (!c) return;
  c.innerHTML = Object.entries(BADGES).map(function(kv) {
    var id = kv[0], b = kv[1];
    return '<div class="badge ' + (state.badges.has(id) ? 'unlocked' : 'locked') + '" data-badge="' + id + '" title="' + b.desc + '">\n' +
      '  <span>' + b.icon + '</span><span class="badge-title">' + b.name + '</span>\n' +
      '</div>';
  }).join('');
}

function awardXP(amount, reason) {
  state.xp += amount;
  while (state.xp >= state.xpToNext) { state.xp -= state.xpToNext; state.level++; state.xpToNext = XP_PER_LEVEL(state.level); UI.toast('Level Up!', 'Reached Level ' + state.level + '!', 'xp'); logActivity('Leveled up to Level ' + state.level + '!', 'xp'); }
  updateXPUI(); StateManager.save(state); UI.toast('+' + amount + ' XP', reason, 'xp');
}

function unlockBadge(id) {
  if (!state.badges.has(id)) { state.badges.add(id); var b = BADGES[id]; if (b) UI.toast('Badge Unlocked!', b.name + ': ' + b.desc, 'xp'); updateBadgesUI(); StateManager.save(state); }
}

