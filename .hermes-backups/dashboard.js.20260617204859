async function handleQuickAction(action) {
  var actions = {
    generate: function() { window.open('http://localhost:8188', '_blank'); },
    upscale: async function() { try { await API.upscale(); UI.toast('Upscale', 'Started', 'success'); logActivity('Upscale', 'success'); } catch (e) { UI.toast('Error', 'Failed', 'error'); } },
    variations: async function() { try { await API.variations(); UI.toast('Variations', 'Started', 'success'); logActivity('Variations', 'success'); } catch (e) { UI.toast('Error', 'Failed', 'error'); } },
    batch: function() { UI.modal('Batch Generate', batchModalContent()); },
    cleanup: async function() { if (confirm('Clean outputs >30 days?')) { try { await API.cleanup(); UI.toast('Cleanup', 'Done', 'success'); logActivity('Cleanup', 'info'); } catch { UI.toast('Error', 'Failed', 'error'); } } },
    backup: async function() { try { await API.backup(); UI.toast('Backup', 'Done', 'success'); logActivity('Backup', 'success'); } catch { UI.toast('Error', 'Failed', 'error'); } },
    report: async function() { try { var t = await API.report(); UI.modal('Daily Report', '<pre style="font-family:var(--font-mono);font-size:0.75rem;white-space:pre-wrap">' + t + '</pre>'); } catch { UI.toast('Error', 'Failed', 'error'); } },
    heal: async function() { try { await API.heal(); UI.toast('Heal', 'Complete', 'success'); logActivity('Self-heal', 'success'); await fetchInitialData(); } catch { UI.toast('Error', 'Failed', 'error'); } },
    security: function() { SecurityPanel.open(); },
    comfy: function() { ComfyManager.open(); },
    workflow: function() { WorkflowBuilder.open(); },
    mature: function() { MatureWorkflows.open(); },
    gpu: function() { GPUPanel.open(0); }
  };
  if (actions[action]) { await actions[action](); logActivity('Action: ' + action, 'system'); }
}

function batchModalContent() {
  return '\n' +
    '    <div style="display:flex;flex-direction:column;gap:16px">\n' +
    '      <div class="field"><label>Prompt</label><textarea class="textarea" id="batch-prompt" rows="4" placeholder="Base prompt"></textarea></div>\n' +
    '      <div class="studio-row">\n' +
