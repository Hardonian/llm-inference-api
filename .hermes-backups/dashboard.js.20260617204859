}

window.startBatch = async function() {
  var prompt = document.getElementById('batch-prompt').value;
  var count = parseInt(document.getElementById('batch-count').value);
  var workflow = document.getElementById('batch-workflow').value;
  if (!prompt) return UI.toast('Error', 'Enter prompt', 'warning');
  UI.closeModal();
  for (var i = 0; i < count; i++) { await queueToComfyUI(prompt + ' --v ' + (i+1), workflow, 'cinematic'); await new Promise(function(r) { setTimeout(r, 500); }); }
  awardXP(25, 'Batch of ' + count); unlockBadge('batch-commander');
};

// ========================================
// WEBSOCKET HANDLING
// ========================================
function handleWSMessage(data) {
  switch (data.type) {
    case 'status': state.services = Object.assign({}, state.services, data.services); renderServices(); break;
    case 'gpu': state.gpus = data.gpu; renderGPUGrid(); break;
    case 'ollama': state.ollamaLanes = data.ollama; renderLaneGrid(); break;
    case 'activity': logActivity(data.msg, data.type, data.xp); break;
    case 'threat': state.security.threats.push(data); SecurityPanel.threats.push(data); if (document.getElementById('tab-threats')) SecurityPanel.open(); break;
    case 'xp': state.xp = data.xp; state.level = data.level; state.xpToNext = data.xpToNext; updateXPUI(); break;
  }
}

// ========================================
// POLLING & UPTIME
// ========================================
function startPolling() { setInterval(function() { if (WSManager.ws && WSManager.ws.readyState !== WebSocket.OPEN) fetchInitialData(); }, 30000); }
function startUptimeCounter() { var s = Date.now(); setInterval(function() { var u = Date.now()-s; var h=Math.floor(u/36e5), m=Math.floor(u%36e5/6e4), sec=Math.floor(u%6e4/1e3); var e=document.getElementById('uptime'); if(e) e.textContent='Up '+h+'h '+m+'m '+sec+'s'; }, 1000); }

// ========================================
// THREAT MONITORING
// ========================================
function startThreatMonitor() {
  setInterval(function() {
    if (state.security.threats.length > 0) {
      var recent = state.security.threats.filter(function(t) { return Date.now() - t.timestamp < 60000; });
      if (recent.length > 5) {
        UI.toast('⚠️ Threat Spike', recent.length + ' threats in last minute', 'threat');
      }
    }
  }, 30000);
}

